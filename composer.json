{
    "name": "lukman-ss/container",
    "description": "A lightweight dependency injection container for PHP.",
    "keywords": [
        "container",
        "dependency-injection",
        "di",
        "psr-11"
    ],
    "support": {
        "issues": "https://github.com/lukman-ss/container/issues",
        "source": "https://github.com/lukman-ss/container"
    },
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Lukman",
            "email": "lukmanumb1@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Lukman\\Container\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lukman\\Container\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
